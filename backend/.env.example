# Port to run FastAPI backend (Render sets this dynamically, defaults to 8000 locally)
PORT=8000

# Power Automate HTTP trigger endpoint URL (Obtain this from Power Automate designer)
POWER_AUTOMATE_URL=https://prod-XX.westus.logic.azure.com:443/workflows/...

# CORS allowed origins (Comma separated list, use * for development)
CORS_ALLOWED_ORIGINS=*
